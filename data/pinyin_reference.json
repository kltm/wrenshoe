          "field": "pinyin",
          "value": "e"
        },
        {
          "field": "approximation",
          "value": "<b>e<b/>"
        },
        {
          "field": "description_field",
          "value": "a diphthong consisting first of a back, unrounded semivowel (which can be formed by first pronouncing \"w\" and then spreading the lips without changing the position of the tongue) followed by a vowel similar to English \"d<b>uh</b>\". Many unstressed syllables in Chinese use the schwa (ide<b>a</b>), and this is also written as \"e\"."
        }
      ],
      "tags": [
        "final"
      ]
    },
