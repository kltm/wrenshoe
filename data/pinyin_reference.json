        {
          "field": "approximation",
          "value": "<u>sh</u>irt"
        },
        {
          "field": "description_field",
          "value": "as in <b>sh</b>oe, but with the tongue curled upwards; very similar to mar<b>sh</b> in American English"
        }
      ],
      "tags": [
        "initial"
      ]
    },
    {
      "field_values": [
        {
          "field": "pinyin",
          "value": "r"
        },
        {
          "field": "approximation",
          "value": "<u>r</u>ay"
        },
        {
          "field": "description_field",
          "value": "Similar to the English <b>z</b> in a<b>z</b>ure and <b>r</b> in <b>r</b>educe, but with the tongue curled upwards, like a cross between English \"r\" and French \"j\". InCyrillised Chinese the sound is rendered with the letter \"ж\"."
        }
      ],
      "tags": [
        "initial"
      ]
    },
